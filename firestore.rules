rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core collections: Allow all operations to support custom authentication
    match /{collectionName}/{docId} {
      allow read, write: if collectionName in [
        'applicants', 
        'admins', 
        'activity_logs', 
        'messages', 
        'admin_config', 
        'notifications',
        'attendance_logs'
      ];
    }
    
    // Recursive matches for nested data or alternate path accesses
    match /{path=**}/{collectionName}/{docId} {
      allow read, write: if collectionName in [
        'applicants', 
        'admins', 
        'activity_logs', 
        'messages', 
        'admin_config', 
        'notifications',
        'attendance_logs'
      ];
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
