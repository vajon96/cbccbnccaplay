rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default-deny safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Explicit Rules for Collections
    match /circular_settings/{id} {
      allow read, write: if true;
    }

    match /circulars/{id} {
      allow read, write: if true;
    }

    match /applicants/{id} {
      allow read, write: if true;
    }

    match /admins/{id} {
      allow read, write: if true;
    }

    match /activity_logs/{id} {
      allow read, write: if true;
    }

    match /messages/{id} {
      allow read, write: if true;
    }

    match /notifications/{id} {
      allow read, write: if true;
    }

    match /counters/{id} {
      allow read, write: if true;
    }

    match /admin_config/{id} {
      allow read, write: if true;
    }

    match /attendance_logs/{id} {
      allow read, write: if true;
    }
  }
}
