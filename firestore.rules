rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Permit all operations for the core collections to ensure 
    // custom-authenticated admins can work correctly.
    
    match /applicants/{id} {
      allow read, write: if true;
    }
    
    match /admins/{id} {
      allow read, write: if true;
    }
    
    match /activity_logs/{id} {
      allow read, write: if true;
    }
    
    match /messages/{id} {
      allow read, write: if true;
    }
    
    match /admin_config/{id} {
      allow read, write: if true;
    }

    // Explicitly allow subcollection recursive matches if any
    match /{path=**}/applicants/{id} { allow read, write: if true; }
    match /{path=**}/admins/{id} { allow read, write: if true; }
    match /{path=**}/activity_logs/{id} { allow read, write: if true; }

    // Final safety fallback
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
