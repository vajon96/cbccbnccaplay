{
  "entities": {
    "applicant": {
      "title": "Applicant",
      "description": "Represents a BNCC enrollment applicant.",
      "type": "object",
      "properties": {
        "fullNameBangla": { "type": "string", "description": "Full name in Bangla" },
        "fullNameEnglish": { "type": "string", "description": "Full name in English" },
        "fatherNameBangla": { "type": "string", "description": "Father's name in Bangla" },
        "fatherNameEnglish": { "type": "string", "description": "Father's name in English" },
        "motherNameBangla": { "type": "string", "description": "Mother's name in Bangla" },
        "motherNameEnglish": { "type": "string", "description": "Mother's name in English" },
        "dob": { "type": "string", "description": "Date of birth" },
        "nidBirthReg": { "type": "string", "description": "NID or Birth Registration number" },
        "gender": { "type": "string", "description": "Gender" },
        "religion": { "type": "string", "description": "Religion" },
        "presentAddress": { "type": "string", "description": "Present address" },
        "permanentAddress": { "type": "string", "description": "Permanent address" },
        "studentPhone": { "type": "string", "description": "Student's phone number" },
        "studentEmail": { "type": "string", "description": "Student's email address" },
        "heightFeet": { "type": "integer", "description": "Height in feet" },
        "heightInches": { "type": "integer", "description": "Height in inches" },
        "weightKg": { "type": "number", "description": "Weight in kg" },
        "bloodGroup": { "type": "string", "description": "Blood group" },
        "sscGpa": { "type": "number", "description": "SSC GPA" },
        "sscGroup": { "type": "string", "description": "SSC group/department" },
        "sscYear": { "type": "string", "description": "SSC passing year" },
        "sscBoard": { "type": "string", "description": "SSC board" },
        "hscGpa": { "type": "string", "description": "HSC GPA" },
        "hscGroup": { "type": "string", "description": "HSC group/department" },
        "hscYear": { "type": "string", "description": "HSC passing year" },
        "hscBoard": { "type": "string", "description": "HSC board" },
        "studyStatus": { "type": "string", "description": "Current study status" },
        "subject": { "type": "string", "description": "Subject" },
        "classRoll": { "type": "string", "description": "Class roll" },
        "section": { "type": "string", "description": "Section" },
        "session": { "type": "string", "description": "Session" },
        "emisId": { "type": "string", "description": "College eMIS ID or Payment Unique Code" },
        "collegeName": { "type": "string", "description": "College name" },
        "photo": { "type": "string", "description": "Base64 encoded photo" },
        "status": { "type": "string", "enum": ["Pending", "Approved", "Rejected"], "description": "Application status" },
        "attendanceStatus": { "type": "string", "enum": ["Present", "Absent"], "description": "Attendance status" },
        "attendanceTime": { "type": "string", "format": "date-time", "description": "Time of attendance marking" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["fullNameBangla", "fullNameEnglish", "fatherNameBangla", "fatherNameEnglish", "motherNameBangla", "motherNameEnglish", "dob", "nidBirthReg", "gender", "religion", "presentAddress", "permanentAddress", "studentPhone", "heightFeet", "heightInches", "weightKg", "bloodGroup", "sscGpa", "sscGroup", "sscYear", "sscBoard", "studyStatus", "subject", "classRoll", "session", "emisId", "collegeName", "photo"]
    },
    "admin_config": {
      "title": "Admin Config",
      "description": "Configuration settings for the admin panel.",
      "type": "object",
      "properties": {
        "key": { "type": "string", "description": "Configuration key" },
        "value": { "type": "string", "description": "Configuration value" }
      },
      "required": ["key", "value"]
    },
    "activity_log": {
      "title": "Activity Log",
      "description": "Log of system and user activities.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["ACCOUNT_CREATED", "PROFILE_UPDATED", "PASSWORD_CHANGED", "PASSWORD_RESET_BY_ADMIN"] },
        "targetId": { "type": "string", "description": "ID of the target entity" },
        "actorId": { "type": "string", "description": "ID of the user who performed the action" },
        "timestamp": { "type": "string", "format": "date-time" },
        "details": { "type": "string" },
        "changes": { "type": "object", "description": "Optional details of changes made" }
      },
      "required": ["type", "targetId", "actorId", "timestamp", "details"]
    },
    "message": {
      "title": "Message",
      "description": "A chat message in the group chat.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string", "description": "ID of the sender" },
        "senderName": { "type": "string", "description": "Name of the sender" },
        "content": { "type": "string", "description": "Message content" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the message was sent" },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "Role of the sender" }
      },
      "required": ["senderId", "senderName", "content", "timestamp", "role"]
    }
  },
  "firestore": {
    "/applicants/{applicantId}": {
      "schema": "applicant",
      "description": "Collection of applicants"
    },
    "/admin_config/{configId}": {
      "schema": "admin_config",
      "description": "Admin configuration settings"
    },
    "/activity_logs/{logId}": {
      "schema": "activity_log",
      "description": "System activity logs"
    },
    "/messages/{messageId}": {
      "schema": "message",
      "description": "Group chat messages"
    }
  }
}
